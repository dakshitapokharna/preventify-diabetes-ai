# Copy this to .env and fill in real values — .env is gitignored, never commit it

# OpenRouter — all LLM calls route through OpenRouter (OpenAI-compatible API)
# Phase 1: google/gemini-2.0-flash-001
# Phase 2: google/gemini-2.5-pro-preview-06-05
# Get keys at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# LLM (Anthropic) — legacy, not used in current pipeline
LLM_API_KEY=your_anthropic_api_key_here
LLM_MODEL=claude-sonnet-4-6

# Postgres / pgvector on Neon — single DB for vectors, user memory, and lead data
# Get this from: neon.tech → your project → Connection Details → Connection string
# Field name in settings.py is `postgres_url` → pydantic reads POSTGRES_URL env var
# Do NOT rename to DATABASE_URL — it will not be picked up by settings.postgres_url
POSTGRES_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/preventify?sslmode=require

# HuggingFace model cache — D: drive only (C: is nearly full, ~300 MB free)
# bge-large-en-v1.5 (~1.3 GB) and bge-reranker-large (~1.1 GB) download here.
# run.py reads this and sets os.environ["HF_HOME"] before loading any model.
# Never change this to a C: path — the download will fail with a disk-full error.
HF_HOME=D:\hf_cache
