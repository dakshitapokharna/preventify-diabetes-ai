# Copy this to .env and fill in values — .env is gitignored

# LLM
LLM_API_KEY=your_anthropic_api_key_here
LLM_MODEL=claude-sonnet-4-6

# Qdrant (local Docker — change URL when moving to cloud)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=preventify_corpus

# Postgres (local Docker — change URL when moving to AWS RDS)
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/preventify
